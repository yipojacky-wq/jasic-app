EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
EXPO_PUBLIC_API_BASE_URL=https://your-api.example.com/v1
EXPO_PUBLIC_DEMO_MODE=true

# Free staging path: use rule-based AI outputs instead of OpenAI API calls.
# Set to openai only when OPENAI_API_KEY is configured as a Supabase Edge secret.
JASIC_AI_MODE=rule_based

# Optional for authenticated staging smoke tests.
# Use a short-lived Supabase user access token, never the service-role key.
JASIC_STAGING_ACCESS_TOKEN=

# Never place OpenAI or Supabase service-role secrets in EXPO_PUBLIC_* variables.
